# ============================================
# Instantly.ai API Configuration
# ============================================
# API Key (v2) — generate at Instantly Dashboard > Settings > Integrations > API
# Required scopes: campaigns:read, leads:read, webhooks:all (or all:all)
INSTANTLY_API_KEY=your_instantly_api_key_here

# Campaign name to monitor for email opens
INSTANTLY_CAMPAIGN_NAME=klaviyo cleaned sup, CAO list Dec 2025

# Sending account email (used to filter the correct campaign context)
INSTANTLY_SENDING_EMAIL=fu@streetlightschools.org

# ============================================
# Day.ai API Configuration
# ============================================
# Integration name — set this, then run: npm run oauth:setup
# The setup wizard will auto-populate CLIENT_ID, CLIENT_SECRET, and REFRESH_TOKEN below.
INTEGRATION_NAME=Willow Instantly Integration
DAY_AI_BASE_URL=https://day.ai

# OAuth credentials (auto-populated by: npm run oauth:setup)
CLIENT_ID=
CLIENT_SECRET=
REFRESH_TOKEN=

# Optional
WORKSPACE_ID=

# ============================================
# Server Configuration
# ============================================
# Port for the webhook server
PORT=3000

# Webhook secret (optional, for validating incoming webhooks)
WEBHOOK_SECRET=

# ============================================
# Polling Configuration (fallback mode)
# ============================================
# How often to poll Instantly for new opens (in minutes)
POLL_INTERVAL_MINUTES=5

# ============================================
# Day.ai Pipeline Configuration
# ============================================
# These will be auto-discovered on first run, or you can set manually.
# Hardcoded fallback IDs from Willow Education workspace:
DAY_AI_PIPELINE_NAME=Sales Pipeline
DAY_AI_PIPELINE_ID=67279be2-3e48-45b1-abfa-ae94a6fe198c
DAY_AI_STAGE_NAME=Unqualified Lead
DAY_AI_STAGE_ID=fad7fcba-2b28-4bcd-979e-435779818487
